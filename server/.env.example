# --- Database ---
# Leave MONGO_URI unset to run a zero-setup LOCAL MongoDB that stores its data
# on disk under server/.data (persists across restarts — no account needed).
# To use a cloud database instead, create a free cluster at
# https://www.mongodb.com/atlas and paste its connection string here:
# MONGO_URI=mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/replog

# --- AI (Google Gemini) ---
# Get a key at https://aistudio.google.com/apikey . Without it the app still
# works, but the AI features (parse / generate / coach) are disabled.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Auth ---
# Secret used to sign login tokens (JWT). Set a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string

# --- Server ---
PORT=4000

# --- ExerciseDB (RapidAPI) — OPTIONAL, one-time GIF sync only ---
# Only needed to (re)download exercise demo GIFs into client/public/exgif via the
# scratchpad scripts. The app itself serves those GIFs statically and needs NO key
# at runtime. Get a free "Basic" key at rapidapi.com/justin-WFnsXH_t6/api/exercisedb
# RAPIDAPI_KEY=
